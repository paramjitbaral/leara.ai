{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A coding project containing multiple files.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project description" },
        "template": { "type": "string", "description": "Project template (React, TypeScript, etc.)" },
        "status": { "type": "string", "description": "Project status (Active, Stable, etc.)" },
        "ownerId": { "type": "string", "description": "User ID of the owner" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isStarred": { "type": "boolean", "description": "Whether the project is starred" }
      },
      "required": ["name", "ownerId"]
    },
    "File": {
      "title": "File",
      "description": "A single file within a project.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "File name" },
        "content": { "type": "string", "description": "File content" },
        "language": { "type": "string", "description": "Programming language" },
        "projectId": { "type": "string", "description": "ID of the parent project" },
        "path": { "type": "string", "description": "File path" }
      },
      "required": ["name", "content", "projectId"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Tracks a user's learning progress on a project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "completedDays": { "type": "array", "items": { "type": "integer" } },
        "lastActiveFile": { "type": "string" }
      },
      "required": ["userId", "projectId"]
    },
    "AICache": {
      "title": "AICache",
      "description": "Caches AI explanations and exercises to save costs.",
      "type": "object",
      "properties": {
        "hash": { "type": "string", "description": "Hash of the code content" },
        "explanation": { "type": "object", "description": "Layered explanation data" },
        "exercises": { "type": "array", "description": "Generated exercises" },
        "questions": { "type": "array", "description": "Generated questions" }
      },
      "required": ["hash"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of user projects"
    },
    "/projects/{projectId}/files/{fileId}": {
      "schema": "File",
      "description": "Files within a project"
    },
    "/userProgress/{progressId}": {
      "schema": "UserProgress",
      "description": "User learning progress"
    },
    "/aiCache/{cacheId}": {
      "schema": "AICache",
      "description": "Cached AI responses"
    }
  }
}
